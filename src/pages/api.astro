---
import Layout from '../layouts/Layout.astro';
import { CodeBlock } from '../components/CodeBlock';

const daemonJsonExample = `{
  "about": "Mario Balbi — CS graduate, Backend Developer & AI/Data Scientist",
  "mission": "Build automation tools that remove real friction...",
  "telos": ["P1: Unnecessary complexity...", "M1: Build tools...", "G1: Land a role..."],
  "current_location": "Camerota, Salerno — Italy",
  "preferences": ["Languages: Python, Java, TypeScript, Go", "..."],
  "favorite_books": ["...", "..."],
  "favorite_movies": ["...", "..."],
  "predictions": ["...", "..."],
  "projects": {
    "technical": ["ZeekXAI — Cyberattack detection with XAI", "..."],
    "creative": ["Homelab — Proxmox VE + NAS + ...", "..."],
    "personal": ["Daemon — This site", "..."]
  },
  "last_updated": "2026-03-30"
}`;

const fetchExample = `const res = await fetch('https://balbus95.github.io/Daemon/daemon.json');
const data = await res.json();

console.log(data.mission);
// "Build automation tools that remove real friction..."

console.log(data.projects.technical[0]);
// "ZeekXAI — Cyberattack detection with Explainable AI"`;
---

<Layout title="Connect | Mario Balbi — Backend Developer & AI/Data Scientist" description="Get in touch with Mario Balbi — open to backend engineering and AI/data roles.">
  <main class="relative z-10 pt-20 pb-20 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Header -->
      <div class="mb-10">
        <h1 class="font-display text-3xl sm:text-4xl text-gradient mb-3">Connect</h1>
        <p class="font-body text-text-secondary">
          I'm currently open to backend engineering and AI/data science roles. Reach out via any of the channels below.
        </p>
      </div>

      <!-- Contact Cards -->
      <section class="mb-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

          <a
            href="mailto:mariobalbi95@gmail.com"
            class="group flex items-center gap-4 p-5 rounded-xl border border-border-default bg-bg-secondary/80 hover:border-brand/50 hover:bg-bg-secondary transition-all duration-300"
          >
            <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-mono text-sm font-semibold text-text-primary group-hover:text-brand transition-colors">Email</p>
              <p class="font-mono text-xs text-text-tertiary">mariobalbi95@gmail.com</p>
            </div>
          </a>

          <a
            href="https://www.linkedin.com/in/mariobalbi95"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 p-5 rounded-xl border border-border-default bg-bg-secondary/80 hover:border-brand/50 hover:bg-bg-secondary transition-all duration-300"
          >
            <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <p class="font-mono text-sm font-semibold text-text-primary group-hover:text-brand transition-colors">LinkedIn</p>
              <p class="font-mono text-xs text-text-tertiary">linkedin.com/in/mariobalbi95</p>
            </div>
          </a>

          <a
            href="https://github.com/Balbus95"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 p-5 rounded-xl border border-border-default bg-bg-secondary/80 hover:border-brand/50 hover:bg-bg-secondary transition-all duration-300"
          >
            <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </div>
            <div>
              <p class="font-mono text-sm font-semibold text-text-primary group-hover:text-brand transition-colors">GitHub</p>
              <p class="font-mono text-xs text-text-tertiary">github.com/Balbus95</p>
            </div>
          </a>

          <div class="flex items-center gap-4 p-5 rounded-xl border border-border-subtle bg-bg-secondary/40">
            <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center shrink-0">
              <span class="w-2.5 h-2.5 rounded-full bg-success animate-pulse-slow"></span>
            </div>
            <div>
              <p class="font-mono text-sm font-semibold text-text-primary">Status</p>
              <p class="font-mono text-xs text-success">Open to opportunities</p>
            </div>
          </div>

        </div>
      </section>

      <!-- About this Daemon -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl text-text-primary mb-4">About this Daemon</h2>
        <p class="font-body text-text-secondary mb-4">
          This site is a personal daemon — a live, public context layer about who I am and what drives me. The data is served as a static JSON file at <a href="https://balbus95.github.io/Daemon/daemon.json" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-brand hover:underline">/daemon.json</a>, freely accessible.
        </p>
        <p class="font-body text-text-secondary mb-6">
          The concept: instead of a static portfolio page, a daemon is always-on context that any AI assistant or interested person can consume. Inspired by <a href="https://danielmiessler.com" class="text-brand hover:underline" target="_blank" rel="noopener noreferrer">Daniel Miessler's</a> vision of personal APIs.
        </p>

        <div class="mb-6">
          <h3 class="font-heading text-lg text-text-primary mb-3">Data Format</h3>
          <CodeBlock code={daemonJsonExample} language="json" client:load />
        </div>

        <div class="mb-6">
          <h3 class="font-heading text-lg text-text-primary mb-3">Fetch Example</h3>
          <CodeBlock code={fetchExample} language="javascript" client:load />
        </div>
      </section>

      <!-- Footer -->
      <section class="border-t border-border-subtle pt-8">
        <p class="font-body text-sm text-text-tertiary italic">
          I authorize the processing of my personal data pursuant to GDPR 679/16.
          All information on this site is public and provided for professional contact purposes.
        </p>
      </section>

    </div>
  </main>
</Layout>
